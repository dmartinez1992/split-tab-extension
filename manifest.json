{
  "manifest_version": 2,
  "name": "Tab Split View",
  "version": "1.0",
  "description": "Split two tabs side by side — current tab on the right, previous tab on the left.",
  "permissions": [
    "tabs"
  ],
  "browser_action": {
    "default_icon": {
      "48": "icons/icon48.png"
    },
    "default_title": "Split Tabs Side by Side"
  },
  "commands": {
    "split-tabs": {
      "suggested_key": {
        "default": "Alt+X"
      },
      "description": "Split tabs into left and right windows"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "48": "icons/icon48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tab-split-view@dmartinez1992",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  }
}
